{
  "sourceLanguage" : "en",
  "strings" : {
    "A new version is available: %@" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しいバージョンがあります: %@"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "새 버전이 있습니다: %@"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有新版本可用：%@"
          }
        }
      }
    },
    "Automatically check for updates" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "自動的にアップデートを確認"
